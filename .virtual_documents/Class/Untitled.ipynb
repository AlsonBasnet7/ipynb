import pandas as pd


import numpy as np


df=pd.read_csv("data.csv")


df.head()


print("__Data Summary__")
df.info()


#data cleaning
#finding the number of missing values
print("__Missing Values__")
print(df.isnull().sum()) # this helps to find the missing values of the data


#handling missing values 


#drop rows  where critcal indentifying is absent (example: name)
df_clean=df.dropna(subset=["Name"])


print(df_clean.head(5))


#imputing and converting non numeric values


df_clean['Salary']=df_clean['Salary'].astype(str).replace(',','',regex=False)
df_clean['Salary']=pd.to_numeric(df_clean['Salary'], errors='coerce')

salary_median=df_clean["Salary"].median()
df_clean["Salary"]=df_clean["Salary"].fillna(salary_median)


#replace missing catergorical data fileds (Departments ) witha descriptiive text label
# Categorical data is data that represents categories or labels instead of numerical measurements.
df_clean["Department"] = df_clean["Department"].fillna("Unassigned")

print("Missing values after initial fixes")

print(df_clean.isnull().sum()[["Name", "Salary", "Department"]])


duplicate_count=df_clean.duplicated().sum()
print(f"Total perfect duplicated row found:{duplicate_count}")



df.clean=df_clean.drop_duplicates()
print(f"Total valid unique records remaining :{len(df_clean)}")


#data type conversion
#replacing 
df_clean['Age']=df_clean['Age'].replace("Thirty","30")
df_clean['Age']=df_clean['Age'].replace("twenty-eight","28")



df_clean['Age'] = pd.to_numeric(df_clean['Age'], errors='coerce')
# df_clean['Age'] = df_clean['Age'].fillna(age_median).astype(int)


df_clean["JoiningDate"] = pd.to_datetime(df_clean["JoiningDate"], errors='coerce')

print("__Structural Data Type Conversions__")

print(df_clean[["Age", "JoiningDate"]].dtypes)




#string operation
#irregular values
#this helps to remove the spaces
df_clean['Name']=df_clean["Name"].str.strip()
df_clean['City']=df_clean["City"].str.strip()



#title case
df_clean["Name"]=df_clean["Name"].str.title()
df_clean["City"]=df_clean["City"].str.title()


#upper cae for core tech identifiers for better structure
df_clean["Department"]=df_clean["Department"].str.upper()



#fill remaining missing city spaces with unkown
df_clean["City"]=df_clean["City"].fillna("Unknown")


print("__Clean Text Field__")
print(df_clean[["Name","Department","City"]].head(5))


df_clean.info()






